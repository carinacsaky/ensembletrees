# Database — source DB (existing company PostGIS)
# For docker-compose self-hosted instance use: DB_HOST=localhost  DB_PORT=5432
DB_HOST=10.100.0.10
DB_PORT=31183
DB_NAME=riskdata
DB_USER=geoserver
DB_PASSWORD=your_db_password_here

# Google Maps Geocoding API (used once; result cached to data/cache/locality_coords_ro.csv)
# Leave blank if you already have data/cache/locality_coords_ro.csv
GOOGLE_API_KEY=your_google_api_key_here
